@model IEnumerable<SmartPlanner.Models.Event>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Мои мероприятия</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Новое мероприятие</a>
</div>

<div class="table-responsive bg-white shadow-sm p-3 rounded">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Название</th>
                <th>Начало</th>
                <th>Конец</th>
                <th>Сфера / Локация</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-bold">@item.Title</div>
                        @if (item.IsRecurring)
                        {
                            <span class="badge bg-info text-dark">Повтор: @item.RecurrenceType</span>
                        }
                    </td>
                    <td>@item.StartTime.ToLocalTime().ToString("g")</td>
                    <td>@item.EndTime.ToLocalTime().ToString("g")</td>
                    <td>
                        <span class="badge bg-secondary">@(item.LifeArea?.Name ?? "—")</span>
                        <div class="small text-muted"><i class="bi bi-geo-alt"></i> @(item.Location?.Name ?? "Не указана")</div>
                    </td>
                    <td>
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Удалить мероприятие?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>