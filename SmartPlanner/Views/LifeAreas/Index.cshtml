@model IEnumerable<SmartPlanner.Models.LifeArea>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Сферы жизни</h2>
    <a asp-action="Create" class="btn btn-primary">+ Добавить сферу</a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100" style="border-left: 5px solid @(item.Color ?? "#ccc")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title">@item.Name</h5>
                        @if (!item.IsActive)
                        {
                            <span class="badge bg-warning text-dark">Архив</span>
                        }
                    </div>
                    <p class="text-muted small">Приоритет: @item.Priority</p>
                    <div class="mt-3 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary text-dark">Изменить</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Удалить сферу? Задачи этой сферы станут общими.')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>