@model IEnumerable<SmartPlanner.Models.Location>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Мои локации</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Добавить локацию</a>
</div>

<div class="bg-white shadow-sm rounded p-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Название</th>
                <th>Адрес</th>
                <th>Часы работы</th>
                <th width="150">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td><span class="text-muted">@(item.Address ?? "Не указан")</span></td>
                    <td>
                        @if (item.OpeningTime.HasValue && item.ClosingTime.HasValue)
                        {
                            <span class="badge bg-light text-dark border">
                                @item.OpeningTime.Value.ToString(@"hh\:mm") — @item.ClosingTime.Value.ToString(@"hh\:mm")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                  onsubmit="return confirm('Удалить локацию? Мероприятия в этой локации останутся без места.')">
                                <button type="submit" class="btn btn-sm btn-outline-danger ms-1">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>