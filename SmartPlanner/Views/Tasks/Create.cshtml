@model SmartPlanner.Models.TaskItem
@using SmartPlanner.Models.Enums

@{
    ViewData["Title"] = "Новая задача";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 shadow-sm p-4 bg-white rounded">
            <h2 class="mb-4">Создание задачи</h2>
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Title" class="form-label font-weight-bold">Название</label>
                        <input asp-for="Title" class="form-control" placeholder="Что нужно сделать?" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    
                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="LifeAreaId" class="form-label">Область жизни</label>
                    <select asp-for="LifeAreaId" class="form-select" asp-items="ViewBag.LifeAreas">
                        <option value="">-- Выберите область --</option>
                    </select>
                </div>

                <hr />

                <div class="row bg-light p-3 rounded mb-3">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Priority" class="form-label text-primary">⭐ Приоритет (1-5)</label>
                        <input asp-for="Priority" type="number" class="form-control" min="1" max="5" value="1" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EnergyRequired" class="form-label text-primary">Энергия (1-5)</label>
                        <input asp-for="EnergyRequired" type="number" class="form-control" min="1" max="5" value="1" />
                    </div>
                    
                    <div class="col-md-6 mb-3">
                        <input type="hidden" name="OriginalEstimatedDuration" id="OriginalEstimatedDuration" value="" />

                        <label asp-for="EstimatedDuration" class="form-label font-weight-bold">Оценка времени (мин)</label>
                        <input asp-for="EstimatedDuration" type="number" class="form-control" placeholder="Напр: 45" id="EstimatedDuration" />
                        <span asp-validation-for="EstimatedDuration" class="text-danger"></span>

                        <div id="ai-suggestion-box" class="mt-2 d-none fade-in">
                            <div class="alert alert-info p-2 mb-0 d-flex justify-content-between align-items-center shadow-sm rounded">
                                <div>
                                    <i class="bi bi-robot text-primary me-1"></i>
                                    <small>ИИ предлагает: <strong id="ai-time" class="text-primary fs-6"></strong> мин.</small>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary py-0 px-2" id="btn-accept-ai">
                                    Применить
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Deadline" class="form-label">Дедлайн</label>
                        <input asp-for="Deadline" type="datetime-local" class="form-control" />
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="IsFlexible" class="form-check-input" type="checkbox" checked />
                    <label asp-for="IsFlexible" class="form-check-label">
                        Гибкая задача (разрешить алгоритму перенос)
                    </label>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    <button type="submit" class="btn btn-success px-5">Создать</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Элементы формы, изменение которых влияет на прогноз
            const inputIds = ['Priority', 'EnergyRequired', 'LifeAreaId', 'EstimatedDuration'];
            const inputs = inputIds.map(id => document.getElementById(id));

            const suggestionBox = document.getElementById('ai-suggestion-box');
            const aiTimeSpan = document.getElementById('ai-time');
            const btnAccept = document.getElementById('btn-accept-ai');
            const originalDurationInput = document.getElementById('OriginalEstimatedDuration');
            const durationInput = document.getElementById('EstimatedDuration');

            let debounceTimer = null;

            // Вешаем слушатели на все важные поля
            inputs.forEach(input => {
                if(input) {
                    input.addEventListener('input', () => {
                        clearTimeout(debounceTimer);
                        // Задержка 700мс, чтобы не отправлять запрос при каждом нажатии клавиши
                        debounceTimer = setTimeout(fetchPrediction, 700);
                    });
                }
            });

            function fetchPrediction() {
                // Если пользователь еще не ввел время, не гадаем
                if (!durationInput.value || durationInput.value <= 0) {
                    suggestionBox.classList.add('d-none');
                    return;
                }

                const requestData = {
                    Priority: parseInt(document.getElementById('Priority').value) || 1,
                    EnergyRequired: parseInt(document.getElementById('EnergyRequired').value) || 1,
                    LifeAreaId: parseInt(document.getElementById('LifeAreaId').value) || null,
                    EstimatedDuration: parseInt(durationInput.value)
                };

                fetch('/Tasks/GetAIPrediction', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestData)
                })
                .then(r => r.json())
                .then(res => {
                    // Показываем подсказку, только если алгоритм предлагает другое время (разница больше 5 минут)
                    if (Math.abs(res.predictedDuration - requestData.EstimatedDuration) >= 5) {
                        aiTimeSpan.textContent = res.predictedDuration;
                        suggestionBox.classList.remove('d-none');
                    } else {
                        suggestionBox.classList.add('d-none');
                    }
                })
                .catch(err => console.error("Ошибка ML:", err));
            }

            // Обработка нажатия на кнопку "Применить"
            btnAccept.addEventListener('click', function() {
                // Запоминаем изначальную мысль пользователя перед тем, как ее затереть
                if (!originalDurationInput.value) {
                    originalDurationInput.value = durationInput.value;
                }

                // Вставляем время ИИ в поле
                durationInput.value = aiTimeSpan.textContent;

                // Прячем плашку и подсвечиваем поле зеленым для красивого эффекта
                suggestionBox.classList.add('d-none');
                durationInput.classList.add('is-valid');
                setTimeout(() => durationInput.classList.remove('is-valid'), 2000);
            });
        });
    </script>
}