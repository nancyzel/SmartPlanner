@model IEnumerable<SmartPlanner.Models.TaskItem>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Мои задачи</h2>
    <a asp-action="Create" class="btn btn-success"> + Новая задача</a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-left-primary">
                <div class="card-body">
                    <h5 class="card-title">@item.Title</h5>
                    <p class="text-muted small">Область: @(item.LifeArea?.Name ?? "Общая")</p>
                    <div class="progress mb-2" style="height: 5px;">
                        <div class="progress-bar" role="progressbar" style="width: @item.ProgressPercent%"></div>
                    </div>
                    <p class="card-text text-truncate">@item.Description</p>
                    <div class="d-flex justify-content-between border-top pt-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Удалить задачу?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>